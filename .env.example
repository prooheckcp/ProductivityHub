# Copy this file to `.env` and fill in the values from your Supabase project
# (Supabase dashboard -> Project Settings -> API).
#
# electron-vite exposes vars prefixed with RENDERER_VITE_ to the renderer
# process, where supabase-js runs. The anon key is a public client key and is
# safe to embed in the app as long as Row Level Security is enabled.

RENDERER_VITE_SUPABASE_URL=https://your-project-ref.supabase.co
RENDERER_VITE_SUPABASE_ANON_KEY=your-anon-public-key
